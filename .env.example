# 本地学习默认不需要填写 DATABASE_URL，会自动使用 SQLite。
# 如果要切换到 PostgreSQL，把下面三行复制到 .env 后再修改。
DATABASE_CLIENT=postgresql
DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/aoxiang
DATABASE_SSL=false

# 后端服务端口，不填时默认是 3001。
PORT=3001

# 管理后台接口令牌。正式上线时请改成一串足够长、不要公开的密码。
ADMIN_API_TOKEN=change_this_to_a_long_random_admin_token
